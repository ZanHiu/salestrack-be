NODE_ENV=development
PORT=3001

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/salestrack?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-me-with-random-32-char-string
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Seed admin user (used by `npm run seed`)
DEFAULT_ADMIN_USERNAME=hop
DEFAULT_ADMIN_PASSWORD=change-me-on-first-login
DEFAULT_ADMIN_FULLNAME=Anh Hop
